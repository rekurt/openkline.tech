# Build-time environment, substituted by Vite (import.meta.env + %VITE_*% in index.html).
#
# In CI (.github/workflows/deploy.yml) these are supplied from GitHub:
#   VITE_SENTRY_DSN        → Actions *Secret*   (error reporting; real secret)
#   VITE_UMAMI_WEBSITE_ID  → Actions *Variable* (public analytics ID)
#   VITE_YANDEX_METRIKA_ID → Actions *Variable* (public analytics ID)
#
# Copy to .env for local dev. The committed .env already ships the public
# analytics IDs as defaults; Sentry only initialises in a production build,
# so it is a no-op locally and can stay empty.

VITE_SENTRY_DSN=
VITE_UMAMI_WEBSITE_ID=1ecb866f-f880-4672-825e-e2d397878bac
VITE_YANDEX_METRIKA_ID=109875855
