# Build-time analytics identifiers, substituted by Vite into index.html (%VITE_*%).
#
# These are PUBLIC, non-secret values — they ship in the page source by design,
# so committing them here is safe. They serve as local-dev / fallback defaults.
#
# In CI (.github/workflows/deploy.yml) these are overridden from GitHub repo
# Variables of the same name (UMAMI_WEBSITE_ID, YANDEX_METRIKA_ID); a real
# process env var takes precedence over this file, so the GitHub values win.
#
# For a local override without touching this file, create .env.local (gitignored).

VITE_UMAMI_WEBSITE_ID=1ecb866f-f880-4672-825e-e2d397878bac
VITE_YANDEX_METRIKA_ID=109875855

# Sentry DSN: real secret in CI (GitHub Actions Secret). Empty locally —
# Sentry only initialises in production builds, so dev/local is a no-op.
VITE_SENTRY_DSN=
