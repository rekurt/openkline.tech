# Build-time analytics identifier, substituted by Vite into index.html (%VITE_*%).
#
# This is a PUBLIC, non-secret value — it ships in the page source by design, so
# committing it here is safe. It serves as the local-dev / fallback default.
#
# In CI (.github/workflows/deploy.yml) it is overridden from the GitHub repo
# Variable UMAMI_WEBSITE_ID; a real process env var takes precedence over this
# file, so the GitHub value wins.
#
# Privacy-first: cookieless Umami only. No Sentry, no Yandex.Metrika.
# For a local override without touching this file, create .env.local (gitignored).

VITE_UMAMI_WEBSITE_ID=1ecb866f-f880-4672-825e-e2d397878bac
